# DeepSeek (chat / extraction / answer)
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama (embeddings)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Models
VEC_LLM_MODEL=deepseek-chat
VEC_EMBEDDING_MODEL=qwen3-embedding:0.6b

# Optional: force offline heuristic mode
# VEC_MODEL_MODE=offline
